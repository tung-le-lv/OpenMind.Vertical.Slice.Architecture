    {
      "id": "scale-title",
      "type": "text",
      "x": 1291.3096554014417,
      "y": 361.2888115776909,
      "width": 362.82940673828125,
      "height": 31.444363064236068,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
