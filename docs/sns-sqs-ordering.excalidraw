      "updated": 1782885165048,
      "link": null,
      "locked": false,
      "text": "[Lambda Instances for order-A]\nProcesses ①→②→③ sequentially in strict order. \nThe next message is delivered only after \nthe current one has been acknowledged by SQS.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "[Lambda Instances for order-A]\nProcesses ①→②→③ sequentially in strict order. \nThe next message is delivered only after \nthe current one has been acknowledged by SQS.",
      "lineHeight": 1.25,
      "version": 556,
      "versionNonce": 1584462027,
      "index": "aX",
